# ── Keeper operator keypairs ──────────────────────────────────────────────────
# Primary keeper secret key (used by keeper-alpha)
KEEPER_SECRET=SABC...

# Two-keeper docker-compose mode
KEEPER_A_SECRET=SABC...
KEEPER_B_SECRET=SABC...

# Display name for this keeper instance
KEEPER_NAME=keeper-alpha

# ── Deployed contract addresses ───────────────────────────────────────────────
# Run ./scripts/testnet-setup.sh to populate these automatically
USDC_CONTRACT=CXXX...        # deployed mock USDC token
REGISTRY_CONTRACT=CXXX...   # KeeperRegistry contract
VAULT_CONTRACT=CYYY...       # NectarVault contract

# Blend pool to monitor for liquidations
BLEND_POOL=CZZZ...

# ── Network config (defaults to Soroban Testnet) ──────────────────────────────
# SOROBAN_RPC=https://soroban-testnet.stellar.org:443
# NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# HORIZON_URL=https://horizon-testnet.stellar.org

# ── Tuning ────────────────────────────────────────────────────────────────────
# POLL_INTERVAL=10        # seconds between keeper cycles (min 3, max 300)
# MIN_PROFIT=1.02         # minimum lot/bid ratio to fill (must be > 0)

# ── Deploy scripts ────────────────────────────────────────────────────────────
# ADMIN_SECRET=SABC...    # Stellar secret for deploying contracts
# ADMIN_ADDRESS=GABC...   # Corresponding public key

# ── Frontend ──────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_REGISTRY_CONTRACT=CXXX...

# ── Performance page (comma-separated list of depositor addresses) ─────────────
# KNOWN_DEPOSITORS=GABC...,GDEF...,GHIJ...
# USER_01_ADDRESS=GABC...
# USER_02_ADDRESS=GDEF...
# ... (15 users generated by scripts/gen-wallets.sh)
# USER_15_ADDRESS=GXYZ...
